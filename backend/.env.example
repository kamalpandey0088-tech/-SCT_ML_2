# ============================================================
# .env.example  —  Environment Configuration Template
# Copy to .env and customise for your deployment
# NEVER commit .env with real secrets to version control
# ============================================================

# Application
APP_NAME="Customer Segmentation API"
APP_VERSION="1.0.0"
DEBUG=false

# Server (for uvicorn production launch)
# HOST=0.0.0.0
# PORT=8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# ML Constraints
MAX_ROWS=50000
MAX_COLS=50
MAX_K=10
MIN_K=2
CSV_MAX_SIZE_BYTES=10485760  # 10 MB

# Logging
LOG_LEVEL=INFO

# CORS — Add your production domain here
# ALLOWED_ORIGINS=["https://your-domain.com","http://localhost:5173"]
